{
  "name": "dev-tools-platform",
  "version": "1.0.0",
  "description": "Micro-Frontend Developer Tools Platform",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "pnpm -r build",
    "build:shell": "pnpm --filter shell build",
    "build:tools": "pnpm --filter './apps/*' --exclude shell build",
    "dev": "pnpm -r --parallel --stream --filter '@dev-tools/shell' --filter '@dev-tools/json-formatter' --filter '@dev-tools/regex-tester' --filter '@dev-tools/jwt-decoder' --filter '@dev-tools/base64-tool' --filter '@dev-tools/password-generator' dev",
    "dev:all": "pnpm -r --parallel --stream dev",
    "dev:shell": "pnpm --filter shell dev",
    "dev:kill": "kill-port 3000 3001 3002 3003 3004 3005",
    "lint": "eslint .",
    "lint:all": "pnpm -r lint",
    "lint:fix": "eslint . --fix",
    "lint:fix:all": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "typecheck:all": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "clean:all": "pnpm -r clean && rm -rf node_modules",
    "test": "pnpm -r test",
    "test:all": "pnpm -r test:run",
    "test:coverage": "pnpm -r test:coverage",
    "test:shell": "pnpm --filter shell test:run",
    "test:tool-sdk": "pnpm --filter @dev-tools/tool-sdk test:run",
    "test:ui": "pnpm --filter @dev-tools/ui test:run",
    "test:utils": "pnpm --filter @dev-tools/utils test:run",
    "ci": "pnpm lint:all &&pnpm typecheck:all && pnpm test:all",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.1.1",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
